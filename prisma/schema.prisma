// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id
  email               String    @unique
  passwordHash        String
  name                String
  title               String
  systemRole          String    @default("member") // "admin" | "member"
  discipline          String?
  phone               String?
  location            String?
  joinDate            DateTime?
  utilization         Int?
  monthlyCompensation Float?
  createdAt           DateTime  @default(now())

  leadProjects      Project[]          @relation("ProjectLead")
  tasks             Task[]
  clientNotes       ClientNote[]
  expenses          Expense[]
  payrollRuns       PayrollRun[]
  mentoredInterns    Intern[]
  leaveRequests     LeaveRequest[]
  knowledgeArticles KnowledgeArticle[]
}

model Project {
  id              String   @id
  name            String
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id])
  typology        String
  location        String
  leadArchitectId String?
  leadArchitect   User?    @relation("ProjectLead", fields: [leadArchitectId], references: [id])
  stage           String
  status          String
  budget          Float
  budgetSpent     Float
  nextMilestone   String
  dueDate         DateTime

  tasks     Task[]
  invoices  Invoice[]
  contracts Contract[]
  expenses  Expense[]
  boqItems  BOQItem[]
}

model Task {
  id         String   @id
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  title      String
  assigneeId String?
  assignee   User?    @relation(fields: [assigneeId], references: [id])
  status     String
  dueDate    DateTime
}

model Client {
  id              String   @id
  company         String
  industry        String
  status          String
  location        String
  contactName     String
  contactRole     String
  contactEmail    String
  contactPhone    String
  lastInteraction DateTime

  projects  Project[]
  notes     ClientNote[]
  leads     Lead[]
  proposals Proposal[]
  contracts Contract[]
  invoices  Invoice[]
}

model ClientNote {
  id       String   @id
  clientId String
  client   Client   @relation(fields: [clientId], references: [id])
  date     DateTime
  authorId String?
  author   User?    @relation(fields: [authorId], references: [id])
  note     String
}

model Lead {
  id          String   @id
  company     String
  contactName String
  stage       String
  estValue    Float
  source      String
  createdDate DateTime
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
}

model Proposal {
  id          String    @id
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  title       String
  value       Float
  status      String
  dateCreated DateTime
  dateSent    DateTime?
}

model Contract {
  id         String    @id
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])
  title      String
  value      Float
  status     String
  signedDate DateTime?
  startDate  DateTime
  endDate    DateTime
}

model Invoice {
  id        String    @id
  number    String    @unique
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  amount    Float
  status    String
  issueDate DateTime
  dueDate   DateTime
  paidDate  DateTime?
}

model Expense {
  id             String   @id
  description    String
  category       String
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id])
  amount         Float
  reimbursable   Boolean
  approvalStatus String
  submittedById  String?
  submittedBy    User?    @relation(fields: [submittedById], references: [id])
  date           DateTime
}

model PayrollRun {
  id                  String   @id
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  monthlyCompensation Float
  lastRunDate         DateTime
  lastRunStatus       String
}

model BOQItem {
  id          String  @id
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  category    String
  description String
  unit        String
  quantity    Float
  unitCost    Float
}

model OpenRole {
  id             String   @id
  title          String
  department     String
  location       String
  employmentType String
  postedDate     DateTime
  status         String

  candidates Candidate[]
}

model Candidate {
  id          String   @id
  roleId      String
  role        OpenRole @relation(fields: [roleId], references: [id])
  name        String
  stage       String
  appliedDate DateTime
  source      String
}

model Intern {
  id        String   @id
  name      String
  school    String
  discipline String
  mentorId  String?
  mentor    User?    @relation(fields: [mentorId], references: [id])
  startDate DateTime
  endDate   DateTime

  milestones InternMilestone[]
}

model InternMilestone {
  id       String @id
  internId String
  intern   Intern @relation(fields: [internId], references: [id])
  label    String
  status   String
  order    Int
}

model LeaveRequest {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  startDate DateTime
  endDate   DateTime
  status    String
  notes     String?
}

model Asset {
  id           String    @id
  name         String
  category     String
  assignedTo   String
  location     String
  status       String
  purchaseDate DateTime
  nextRenewal  DateTime?
}

model KnowledgeArticle {
  id          String   @id
  title       String
  category    String
  tags        String
  summary     String
  lastUpdated DateTime
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
}

model Template {
  id          String   @id
  name        String
  type        String
  description String
  lastUpdated DateTime
  owner       String
}

model LibraryItem {
  id       String   @id
  name     String
  category String
  format   String
  icon     String
  color    String
  updated  DateTime
}

model AutomationRule {
  id          String  @id
  name        String
  description String
  trigger     String
  action      String
  enabled     Boolean
}

model Integration {
  id          String  @id
  name        String
  category    String
  description String
  icon        String
  connected   Boolean
}
